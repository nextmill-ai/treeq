# Copy to .env.local for `netlify dev`. In production set these in
# Netlify dashboard → Site settings → Environment variables. NEVER commit .env.local.

# Anthropic — for Claude Sonnet 4.6 estimator
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Notion — internal integration token, shared with the 5 TreeQ Source Data databases
# in SpartanTreeNY's workspace
NOTION_API_KEY=secret_REPLACE_ME

# Supabase — service-role key bypasses RLS (server-side ONLY; never expose to client)
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs_REPLACE_ME

# Tenant: hardcoded org ID for Stage 1 (auth wiring comes later)
# Query: select id from organizations where slug = 'spartan';
SPARTAN_ORG_ID=00000000-0000-0000-0000-000000000000

# Notion database IDs (with or without dashes). These are constants and
# can be checked into version control — they're not secrets, just IDs.
NOTION_DB_DUMP_SPOTS=5a378d387d3a4b028c59d0957aa43e60
NOTION_DB_VENDORS=d080dcedef8e468885abcd5b7cf4162d
NOTION_DB_SUBCONTRACTORS=9fa3089d9c30497c961a29f2a4617d3b
NOTION_DB_PLANT_PRICES=2179afd2a7594924bcd1525d74c755e8
NOTION_DB_PICKUP_SPOTS=501bc730a26c45448496c9178c2a3980

# OpenAI — Whisper (transcribe) + text-embedding-3-small (RAG embeddings)
OPENAI_API_KEY=sk-REPLACE_ME

# Jobber webhook secret — set after registering the Jobber app + webhook subscription
JOBBER_WEBHOOK_SECRET=REPLACE_ME

# Supabase — anon/public key (safe for client-side; RLS must be correct)
# Needed once Capacitor app or PowerSync makes direct Supabase calls from the device.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs_REPLACE_ME

# Twilio — SMS fallback estimates (offline users, feature-flagged)
TWILIO_ACCOUNT_SID=ACREPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_FROM_NUMBER=+1REPLACE_ME

# Auth gate. Default off in v0.1 (free build). Flip to "true" when ready to gate
# pages and require Supabase Auth sign-in.
TREEQ_AUTH_ENABLED=false

# ── Cursor MCP env vars (set in Cursor Settings → MCP, NOT in Netlify) ──────────
# These are only consumed by .cursor/mcp.json — not by Netlify Functions.
# SUPABASE_ACCESS_TOKEN=sbp_REPLACE_ME        # Supabase Management API PAT
# SUPABASE_PROJECT_REF=REPLACE_ME             # Project ref from supabase.com/dashboard
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_REPLACE_ME
# NOTION_API_KEY is shared — already defined above, also set in Cursor MCP env.
